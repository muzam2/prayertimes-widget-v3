<?xml version="1.0" encoding="utf-8"?>
<!--
  prayer_widget_info.xml
  ─────────────────────
  Registers the widget with Android's AppWidget framework.
  No configure activity — the JSON timetable is global to the app, so once
  imported via MainActivity it's visible to every widget instance.
  This is required for compatibility with Samsung Good Lock / LockStar,
  which doesn't reliably run third-party config activities.
-->
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="3"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/prayer_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen|keyguard"
    android:widgetFeatures="reconfigurable" />
