<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Prayer Times Widget"
        android:textColor="#4CAF9F"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="London Central Mosque (ICC) timetable"
        android:textColor="#AAAACC"
        android:textSize="12sp"
        android:layout_marginBottom="28dp" />

    <!-- Step 1 — city label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 1 — City name (widget display label)"
        android:textColor="#CCCCDD"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_city"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. London"
        android:inputType="textCapWords"
        android:textColor="#FFFFFF"
        android:textColorHint="#666688"
        android:backgroundTint="#4CAF9F"
        android:layout_marginBottom="24dp" />

    <!-- Step 2 — JSON import -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 2 — Import annual timetable JSON"
        android:textColor="#CCCCDD"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Copy icc_2026_final.json to your phone, then tap the button below and select it."
        android:textColor="#888899"
        android:textSize="11sp"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_import_json"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Import JSON file"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A4A5E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_timetable_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No timetable loaded"
        android:textColor="#FFCC88"
        android:textSize="12sp"
        android:layout_marginBottom="28dp" />

    <Button
        android:id="@+id/btn_add_widget"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Add Widget to Lock Screen"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF9F"
        android:textStyle="bold"
        android:textSize="15sp" />

</LinearLayout>
