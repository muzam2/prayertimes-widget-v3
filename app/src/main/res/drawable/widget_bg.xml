<?xml version="1.0" encoding="utf-8"?>
<!--
  widget_bg.xml
  ─────────────
  Semi-transparent dark rounded rectangle.
  Works on both dark and light wallpapers on the lock screen.
  Alpha ~85% so the wallpaper can still breathe slightly behind it.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- #D9 = 85% opacity -->
    <solid android:color="#D91A1A2E" />

    <corners android:radius="16dp" />

    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />

</shape>
